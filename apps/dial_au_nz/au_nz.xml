<?xml version="1.0" encoding ="utf-8" ?>
<application xmlns="http://kotuku.aero/schema/kotuku.xsd"
             xmlns:xs="http://www.w3.org/2001/XMLSchema">
  <id>id_units</id>
  <!--<id>id_display_units</id>-->
  <id>id_cancel_alarm</id>
  <id>id_snooze_alarm</id>
  <id>id_toggle_vs_mode</id>
  <id>id_toggle_hs_mode</id>

  <menu id =" 100"
        root-keys="root"
        alarm-keys="alarm_keys"
        font="neo_9_font"
        background-color="color_black"
        fill-background="false"
        selected-background-color="color_white"
        selected-color="color_magenta"
        border-color="color_yellow"
        text-color="color_green"
        menu-timeout="7">
    <rect left="220" top="340" width="584" height="240"/>
    <menu-rect x="0" y="0"/>
    <menu-start x="0" y="240"/>
    <!-- relative to parent! -->
    <captions x="221" y="580" width="581" height="20">
      <button key-name="kn_decka" left="0" top="0" width="83" height="20"/>
      <button key-name="kn_key2" left="83" top="0" width="83" height="20"/>
      <button key-name="kn_key3" left="166" top="0" width="83" height="20"/>
      <button key-name="kn_key4" left="249" top="0" width="83" height="20" />
      <button key-name="kn_key5" left="332" top="0" width="83" height="20"/>
      <button key-name="kn_key6" left="415" top="0" width="83" height="20"/>
      <button key-name="kn_deckb" left="498" top="0" width="83" height="20"/>
    </captions>
    <!-- Menu used when the menu is closed -->
    <keys name="root">
      <key0 caption="Info/Settings">
        <popup-action caption="Settings" menu="settings_menu" />
      </key0>
      <decka-up>
        <event-action caption="Next" can-id="id_marquee_next" value-type="v_int16" value="1"/>
      </decka-up>
      <decka-dn>
        <event-action caption="Prev" can-id="id_marquee_prev" value-type="v_int16" value="1"/>
      </decka-dn>

      <key1 caption="HDG/QNH">
        <event-action caption="Cancel" can-id="id_cancel" value-type="v_int16" value="1"/>
      </key1>
      <deckb-up>
        <event-action caption="Up" can-id="id_heading_change" value-type="v_int16" value="1"/>
      </deckb-up>
      <deckb-dn>
        <event-action caption="Up" can-id="id_heading_change" value-type="v_int16" value="-1"/>
      </deckb-dn>
      <deckb-press-up>
        <event-action caption="Up" can-id="id_qnh_change" value-type="v_int16" value="1"/>
      </deckb-press-up>
      <deckb-press-dn>
        <event-action caption="Dn" can-id="id_qnh_change" value-type="v_int16" value="-1"/>
      </deckb-press-dn>

      <key2 caption="VS Mode">
        <event-action caption="Cancel" can-id="id_toggle_vs_mode" value-type="v_int16" value="1"/>
      </key2>
      <hold-key2>
        <event-action caption="AP Reverse Left" can-id="id_ap_reverse" value-type="v_int16" value="1"/>
      </hold-key2>
      <key3 caption="AP Mode">
        <popup-action caption="AP Mode" menu="ap_menu" />
      </key3>
      <hold-key3>
        <event-action caption="AP Cancel" can-id="id_autopilot_enable" value-type="v_int16" value="0"/>
      </hold-key3>
      <key4 caption="HS Mode">
        <event-action caption="VS Up" can-id="id_toggle_hs_mode" value-type="v_int16" value="1"/>
      </key4>
      <hold-key4>
        <event-action caption="AP Reverse right" can-id="id_ap_reverse" value-type="v_int16" value="-1"/>
      </hold-key4>
    </keys>
    <!-- Menu used when an alarm is displayed -->
    <keys name="alarm_keys">
      <key0>
        <event-action caption="Close" can-id="id_alarm_close" value-type="v_int16" value="1"/>
      </key0>
      <key1>
        <event-action caption="Park" can-id="id_alarm_park" value-type="v_int16" value="1"/>
      </key1>
    </keys>

    <!-- Menu used when a popup is active -->
    <keys name="popup_keys">
      <key0>
        <event-action caption="OK" can-id="id_ok" value-type="v_int16" value="1"/>
      </key0>
      <key1>
        <event-action caption="Cancel" can-id="id_cancel" value-type="v_int16" value="1"/>
      </key1>
      <decka-up>
        <event-action caption="Up" can-id="id_up" value-type="v_int16" value="1"/>
      </decka-up>
      <decka-dn>
        <event-action caption="Dn" can-id="id_down" value-type="v_int16" value="1"/>
      </decka-dn>
    </keys>

    <keys name="edit_keys">
      <key0 caption="OK">
        <event-action caption="OK" can-id="id_ok" value-type="v_int16" value="1"/>
      </key0>
      <key2 caption="Cancel">
        <event-action caption="Cancel" can-id="id_cancel" value-type="v_int16" value="1"/>
      </key2>
      <decka-up>
        <event-action caption="Up" can-id="id_spin_edit" value-type="v_int16" value="10"/>
      </decka-up>
      <decka-dn>
        <event-action caption="Dn" can-id="id_spin_edit" value-type="v_int16" value="-10"/>
      </decka-dn>
      <decka-press-up>
        <event-action caption="Up" can-id="id_spin_edit" value-type="v_int16" value="1"/>
      </decka-press-up>
      <decka-press-dn>
        <event-action caption="Dn" can-id="id_spin_edit" value-type="v_int16" value="-1"/>
      </decka-press-dn>
    </keys>

    <menu name="settings_menu" keys="popup_keys" caption="Settings">
      <popup-action caption="Config" menu="config_menu" />
      <popup-action caption="Fuel" menu="fuel_menu" />
    </menu>

    <menu name="config_menu" keys="popup_keys" caption="Config">
      <spin-edit-action caption="Brightness"
                        min-value="10"
                        max-value="100"
                        get-method="get_brightness"
                        set-method="set_brightness"
                        keys="edit_keys"/>
    </menu>

    <menu name="fuel_menu" keys="popup_keys" caption="Fuel">
      <event-action caption="Full Fuel" can-id="id_set_fuel_available" value-type="v_uint16" get-value="get_fuel_max"/>
      <spin-edit-action caption="Fuel total"
                        min-value="0"
                        get-max-value="get_fuel_max"
                        converter="convert_cc_to_litres"
                        get-method="get_fuel_total"
                        set-method="set_fuel_total"
                        keys="edit_keys"/>
    </menu>

    <menu name="ap_menu" keys="popup_keys" caption="AP">
      <checklist-action caption="Mode" get-index="get_autopilot_mode" popup="ap_mode_menu" />
    </menu>

    <menu name="ap_mode_menu" keys="popup_keys" caption="AP Mode">
      <event-action caption="None" can-id="id_autopilot_enable" value-type="v_uint16" value="0x0000"/>
      <event-action caption="ALT" can-id="id_autopilot_enable" value-type="v_uint16" value="0x0003"/>
      <event-action caption="NAV" can-id="id_autopilot_enable" value-type="v_uint16" value="0x0005"/>
      <event-action caption="ALT+NAV" can-id="id_autopilot_enable" value-type="v_uint16" value="0x0007"/>
    </menu>
  </menu>

